POSTGRES_USER=reliability
POSTGRES_PASSWORD=reliability
POSTGRES_DB=reliability_store

DATABASE_URL=postgresql://reliability:reliability@postgres:5432/reliability_store

ENVIRONMENT=local

# Portas dos serviços
BACKEND_PORT=80
FRONTEND_PORT=5173

# Inter-service
PRODUCT_SERVICE_URL=http://product-service:8001
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Observabilidade
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
LOKI_PORT=3100
TEMPO_PORT=3200

# CORS: origens aceitas pelos backends (separadas por vírgula)
CORS_ORIGINS=http://localhost,http://localhost:5173,http://127.0.0.1:5173

# URL da API como o navegador a enxerga — aponta para o nginx na porta 80
VITE_API_BASE_URL=http://localhost
