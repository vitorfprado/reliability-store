POSTGRES_USER=reliability
POSTGRES_PASSWORD=reliability
POSTGRES_DB=reliability_store

DATABASE_URL=postgresql://reliability:reliability@postgres:5432/reliability_store

APP_NAME=Reliability Store API
ENVIRONMENT=local

FRONTEND_PORT=5173
BACKEND_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Origens permitidas pelo CORS (navegador). Separadas por vírgula.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# URL da API como o navegador a enxerga (host), não use o nome do serviço Docker aqui.
VITE_API_BASE_URL=http://localhost:8000
